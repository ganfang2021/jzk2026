/* pages/list/list.wxss - v3 患者列表页面样式 */

/* ==================== 用户信息头 ==================== */
.user-info {
  background: var(--primary-gradient-deep);
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
  margin-bottom: var(--spacing-lg);
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(13, 71, 161, 0.25);
  position: relative;
  overflow: hidden;
}

.user-info::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -10%;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  pointer-events: none;
}

.user-name {
  font-size: var(--font-lg);
  font-weight: 600;
  position: relative;
  z-index: 1;
}

.patient-count {
  font-size: var(--font-sm);
  opacity: 0.85;
  position: relative;
  z-index: 1;
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 120rpx var(--spacing-xl);
}

/* ==================== 仅查看标识 ==================== */
.patient-view-only {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-md);
}

.patient-view-only text {
  color: var(--text-hint);
  font-size: var(--font-xs);
}

/* ==================== 分页 ==================== */
.pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-xl);
  background: var(--surface);
  border-radius: var(--radius-lg);
  margin-top: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

.page-btn {
  padding: var(--spacing-md) var(--spacing-xl);
  background: var(--primary-gradient);
  color: #ffffff;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

.page-btn:active {
  transform: scale(0.96);
}

.page-info {
  font-size: var(--font-md);
  color: var(--text-secondary);
}

.load-more-tip {
  text-align: center;
  padding: 24rpx;
  font-size: var(--font-sm);
  color: var(--text-disabled);
}

/* ==================== OCR标识 ==================== */
.ocr-badge {
  display: inline-block;
  font-size: 18rpx;
  font-weight: 600;
  color: #ffffff;
  background: var(--primary);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  vertical-align: middle;
  line-height: 32rpx;
}

.btn-icon.ocr {
  background: #E3F2FD;
  color: var(--primary);
}

.btn-icon.detail {
  background: #FFF8E1;
  color: #F57C00;
}
