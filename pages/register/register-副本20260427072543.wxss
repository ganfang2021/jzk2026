/* pages/register/register.wxss - v3 深蓝医疗主题 */

.register-container {
  min-height: 100vh;
  background: linear-gradient(145deg, #0D47A1 0%, #1565C0 35%, #1A73E8 65%, #4A90D9 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: var(--spacing-3xl);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* ==================== 装饰性背景圆环 ==================== */
.register-container .deco-circle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.reg-deco-1 {
  width: 500rpx;
  height: 500rpx;
  top: -150rpx;
  left: -100rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.reg-deco-2 {
  width: 350rpx;
  height: 350rpx;
  bottom: 15%;
  right: -80rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.reg-deco-3 {
  width: 700rpx;
  height: 700rpx;
  bottom: -250rpx;
  left: -150rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.03);
}

/* ==================== 头部品牌区 ==================== */
.register-header {
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.register-header .logo-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.register-header .logo-ring {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  animation: ringPulse 3s ease-in-out infinite;
}

.register-header .logo {
  width: 110rpx;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 3rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.register-header .logo-icon {
  font-size: 52rpx;
}

.register-header .title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.register-header .subtitle {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 3rpx;
  font-weight: 300;
}

/* ==================== 注册卡片 ==================== */
.register-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-2xl);
  padding: 32rpx 28rpx;
  box-shadow: 0 20rpx 60rpx rgba(13, 71, 161, 0.35);
  position: relative;
  z-index: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.register-card-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.register-card-header .card-header-icon {
  font-size: var(--font-xl);
  margin-right: var(--spacing-md);
}

.register-card-header .card-header-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

/* ==================== 表单 ==================== */
.register-card .form-item {
  margin-bottom: 24rpx;
}

.register-card .form-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
  letter-spacing: 0.3rpx;
  display: flex;
  align-items: center;
}

.register-card .required {
  color: var(--danger);
  margin-left: var(--spacing-xs);
  font-size: var(--font-base);
}

.register-card .input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--surface-alt);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  transition: var(--transition-fast);
}

.register-card .input-wrapper:focus-within,
.register-card .input-wrapper.picker-wrapper:active {
  border-color: var(--primary);
  background: var(--surface);
  box-shadow: 0 0 0 4rpx rgba(26, 115, 232, 0.08);
}

.register-card .input-icon {
  flex-shrink: 0;
  width: 72rpx;
  text-align: center;
  font-size: var(--font-lg);
  color: var(--text-hint);
}

.register-card .form-input {
  flex: 1;
  height: 84rpx;
  padding-right: var(--spacing-lg);
  font-size: var(--font-base);
  color: var(--text-primary);
  background: transparent;
  box-sizing: border-box;
  caret-color: var(--primary);
}

.register-card .form-input::placeholder {
  color: var(--text-disabled);
}

.register-card .picker-value {
  display: flex;
  align-items: center;
  padding-right: 60rpx;
  position: relative;
}

.register-card .picker-value::after {
  content: '';
  position: absolute;
  right: var(--spacing-lg);
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid var(--text-hint);
  border-bottom: 3rpx solid var(--text-hint);
  transform: rotate(45deg);
  margin-top: -8rpx;
}

/* ==================== 注册按钮 ==================== */
.register-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(145deg, #1A73E8 0%, #4A90D9 100%);
  color: #ffffff;
  border-radius: var(--radius-xl);
  font-size: var(--font-xl);
  font-weight: 700;
  margin-top: 28rpx;
  border: none;
  letter-spacing: 6rpx;
  box-shadow: 0 6rpx 24rpx rgba(26, 115, 232, 0.35);
  transition: var(--transition);
}

.register-btn::after {
  border: none;
}

.register-btn:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(26, 115, 232, 0.25);
}

.register-btn[disabled] {
  opacity: 0.6;
  transform: none;
  box-shadow: none;
}

/* ==================== 底部链接 ==================== */
.register-card .form-footer {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.register-card .form-footer .link {
  font-size: var(--font-md);
  color: var(--primary);
  font-weight: 500;
  padding: 10rpx 4rpx;
}

.register-card .form-footer .link:active {
  opacity: 0.65;
}

@keyframes ringPulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.08); opacity: 0.6; }
  100% { transform: scale(1); opacity: 1; }
}
