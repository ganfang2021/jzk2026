/* pages/stats/stats.wxss - v3 数据统计页面样式 */

/* ==================== 统计页面专用容器 ==================== */
/* 继承 app.wxss 中的 .container, .card, .card-title, .time-filter, .time-btn 等 */

/* ==================== 管理员查看模式 ==================== */
.admin-view-mode {
  display: flex;
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-2xl);
}

.mode-btn {
  flex: 1;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  text-align: center;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
  transition: var(--transition);
  border: 1rpx solid var(--border-light);
}

.mode-btn:active {
  opacity: 0.7;
}

.mode-btn.active {
  background: var(--primary-gradient);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(26, 115, 232, 0.2);
}

/* ==================== 用户数据列表 ==================== */
.user-data-list {
  margin-bottom: var(--spacing-2xl);
}

.user-stats-list {
  padding: 0;
}

.user-stats-item {
  padding: var(--spacing-xl) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.user-stats-item:last-child {
  border-bottom: none;
}

.user-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.user-stats-row {
  display: flex;
  flex-wrap: wrap;
}

.user-stat {
  display: flex;
  align-items: center;
  margin-right: var(--spacing-2xl);
  margin-bottom: var(--spacing-xs);
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-right: var(--spacing-xs);
}

.stat-value {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 100rpx var(--spacing-xl);
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-disabled);
  margin-top: var(--spacing-lg);
}

/* ==================== 趋势图 ==================== */
.trend-toggle {
  display: flex;
  gap: var(--spacing-sm);
}

.trend-btn {
  padding: var(--spacing-xs) var(--spacing-lg);
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 500;
  color: var(--text-hint);
  background: var(--surface-alt);
  border: 1rpx solid var(--border-light);
  transition: var(--transition-fast);
}

.trend-btn.active {
  background: var(--primary-gradient);
  color: #fff;
  border-color: transparent;
}

.chart-wrapper {
  width: 100%;
  height: 360rpx;
  margin-bottom: var(--spacing-md);
}

.trend-canvas {
  width: 100%;
  height: 100%;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: var(--spacing-xl);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--border-light);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
}

/* ==================== 色彩辅助覆盖 ==================== */
.text-danger { color: var(--danger) !important; }
.text-warning { color: var(--warning) !important; }
.text-success { color: var(--success) !important; }
.stat-primary { color: var(--primary); }
.stat-danger { color: var(--danger); }
.stat-success { color: var(--success); }
