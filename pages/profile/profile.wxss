/* pages/profile/profile.wxss - v3 深蓝医疗主题 */

.profile-container {
  min-height: 100vh;
  background: var(--background);
  padding: var(--spacing-2xl);
  position: relative;
  overflow: hidden;
}

/* ==================== 装饰性背景元素 ==================== */
.p-deco-1 {
  position: absolute;
  top: -200rpx;
  right: -200rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(26, 115, 232, 0.04) 0%, transparent 70%);
  pointer-events: none;
}

.p-deco-2 {
  position: absolute;
  bottom: -150rpx;
  left: -150rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(26, 115, 232, 0.03) 0%, transparent 70%);
  pointer-events: none;
}

/* ==================== 用户卡片 ==================== */
.user-card {
  background: linear-gradient(145deg, #0D47A1 0%, #1A73E8 50%, #4A90D9 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx 36rpx;
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-2xl);
  box-shadow: 0 8rpx 32rpx rgba(13, 71, 161, 0.3);
  position: relative;
  overflow: hidden;
}

.user-card-bg {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  pointer-events: none;
}

.avatar-wrapper {
  position: relative;
  width: 130rpx;
  height: 130rpx;
  margin-right: var(--spacing-2xl);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-ring {
  position: absolute;
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.avatar {
  width: 105rpx;
  height: 105rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 3rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 48rpx;
}

.user-info {
  flex: 1;
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.user-name {
  font-size: var(--font-2xl);
  font-weight: 700;
  margin-bottom: var(--spacing-sm);
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.user-role {
  margin-bottom: var(--spacing-sm);
}

.role-badge {
  display: inline-block;
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  backdrop-filter: blur(8rpx);
}

.user-id {
  font-size: var(--font-xs);
  opacity: 0.75;
}

/* ==================== 信息卡片 ==================== */
.info-card {
  margin-bottom: var(--spacing-2xl);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.info-value {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
  text-align: right;
  max-width: 60%;
}

/* ==================== 操作列表 ==================== */
.action-card {
  margin-bottom: var(--spacing-2xl);
}

.action-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-xl) 0;
  border-bottom: 1rpx solid var(--border-light);
  transition: var(--transition-fast);
}

.action-item:last-child {
  border-bottom: none;
}

.action-item:active {
  opacity: 0.7;
  transform: translateX(4rpx);
}

.action-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: var(--spacing-lg);
  flex-shrink: 0;
}

.action-item-text {
  flex: 1;
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

.action-item-arrow {
  color: var(--border);
  font-size: var(--font-xl);
  font-weight: 300;
  padding-left: var(--spacing-md);
}

/* ==================== 数据管理 ==================== */
.sync-hint {
  font-size: var(--font-xs);
  color: var(--text-hint);
  padding-top: var(--spacing-sm);
  padding-left: calc(72rpx + var(--spacing-lg));
  line-height: 1.4;
}

/* ==================== 版本信息 ==================== */
.version-info {
  text-align: center;
  padding: var(--spacing-3xl) 0;
}

.version-text {
  font-size: var(--font-sm);
  color: var(--text-disabled);
}

/* ==================== 管理员 - 用户管理 ==================== */
.user-mgmt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.user-mgmt-hint {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.user-mgmt-add-btn {
  font-size: var(--font-sm);
  color: var(--primary);
  font-weight: 600;
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--radius-md);
  background: var(--primary-lightest);
}

.user-mgmt-add-btn:active {
  opacity: 0.7;
}

.user-mgmt-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.user-mgmt-item:last-child {
  border-bottom: none;
}

.user-mgmt-avatar {
  font-size: 40rpx;
  margin-right: var(--spacing-lg);
  flex-shrink: 0;
  width: 64rpx;
  text-align: center;
}

.user-mgmt-info {
  flex: 1;
  min-width: 0;
}

.user-mgmt-name {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.user-mgmt-role {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}

.user-mgmt-role.doctor {
  background: #E3F2FD;
  color: #1565C0;
}

.user-mgmt-role.nurse {
  background: #FCE4EC;
  color: #C62828;
}

.user-mgmt-role.admin {
  background: #FFF3E0;
  color: #E65100;
}

.user-mgmt-badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-full);
  background: #E8F5E9;
  color: #2E7D32;
  font-weight: 400;
}

.user-mgmt-meta {
  display: flex;
  gap: var(--spacing-2xl);
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.user-mgmt-actions {
  flex-shrink: 0;
  margin-left: var(--spacing-md);
}

.mgmt-btn {
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  font-weight: 500;
  text-align: center;
  min-width: 64rpx;
}

.mgmt-btn:active {
  opacity: 0.7;
}

.mgmt-delete {
  background: var(--danger-bg);
  color: var(--danger);
}
