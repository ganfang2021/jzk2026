/* pages/textedit/textedit.wxss */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* ==================== 工具栏 ==================== */
.toolbar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
  flex-wrap: wrap;
  gap: 10rpx;
}

.toolbar-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.toolbar-btn {
  min-width: 64rpx;
  height: 56rpx;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toolbar-btn:active {
  background: #e0e0e0;
}

.toolbar-btn.active {
  background: #1A73E8;
  color: #fff;
}

.toolbar-btn.disabled {
  color: #ccc;
}

.toolbar-divider {
  width: 2rpx;
  height: 40rpx;
  background: #e0e0e0;
  margin: 0 8rpx;
}

/* ==================== 格式栏 ==================== */
.format-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
  gap: 40rpx;
}

.format-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.format-label {
  font-size: 26rpx;
  color: #666;
}

.format-value {
  padding: 8rpx 24rpx;
  background: #1A73E8;
  color: #fff;
  border-radius: 6rpx;
  font-size: 24rpx;
}

/* ==================== 编辑区域 ==================== */
.editor-wrap {
  flex: 1;
  padding: 20rpx;
  background: #fff;
}

.editor {
  width: 100%;
  height: 100%;
  padding: 24rpx;
  background: #fafafa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  box-sizing: border-box;
  text-align: left;
}

/* ==================== 查找面板 ==================== */
.find-panel {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 60rpx rgba(0,0,0,0.3);
  z-index: 1000;
}

.find-input-wrap {
  display: flex;
  gap: 20rpx;
}

.find-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.find-btn {
  width: 120rpx;
  height: 80rpx;
  background: #1A73E8;
  color: #fff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.find-result {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

.find-close {
  margin-top: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #e8e8e8;
}

.bottom-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.char-count {
  font-size: 24rpx;
  color: #999;
}

.history-info {
  font-size: 24rpx;
  color: #1A73E8;
}

.bottom-btns {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  background: #f0f0f0;
  color: #333;
}

.btn:active {
  opacity: 0.8;
}

.btn.disabled {
  color: #ccc;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: #1A73E8;
  color: #fff;
}
