/* pages/login/login.wxss - v3 深蓝医疗主题 */

.login-container {
  min-height: 100vh;
  background: linear-gradient(145deg, #0D47A1 0%, #1565C0 35%, #1A73E8 65%, #4A90D9 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: var(--spacing-3xl);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* ==================== 装饰性背景圆环 ==================== */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.deco-1 {
  width: 600rpx;
  height: 600rpx;
  top: -200rpx;
  right: -150rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.deco-2 {
  width: 400rpx;
  height: 400rpx;
  bottom: 10%;
  left: -100rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.deco-3 {
  width: 200rpx;
  height: 200rpx;
  top: 40%;
  right: 10%;
  border: 2rpx solid rgba(255, 255, 255, 0.04);
}

.deco-4 {
  width: 800rpx;
  height: 800rpx;
  bottom: -300rpx;
  right: -200rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.03);
}

/* ==================== 头部品牌区 ==================== */
.login-header {
  text-align: center;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 1;
}

.logo-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-ring {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  animation: ringPulse 3s ease-in-out infinite;
}

.logo {
  width: 130rpx;
  height: 130rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 3rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.logo-icon {
  font-size: 64rpx;
}

.login-header .title {
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.login-header .subtitle {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 3rpx;
  font-weight: 300;
}

/* ==================== 登录卡片 ==================== */
.login-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-2xl);
  padding: 36rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(13, 71, 161, 0.35);
  position: relative;
  z-index: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.login-card-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.card-header-icon {
  font-size: var(--font-xl);
  margin-right: var(--spacing-md);
}

.card-header-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

/* ==================== 表单 ==================== */
.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--surface-alt);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  transition: var(--transition-fast);
}

.input-wrapper:focus-within {
  border-color: var(--primary);
  background: var(--surface);
  box-shadow: 0 0 0 4rpx rgba(26, 115, 232, 0.08);
}

.input-icon {
  flex-shrink: 0;
  width: 72rpx;
  text-align: center;
  font-size: var(--font-lg);
  color: var(--text-hint);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-lg);
  background: var(--surface-alt);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--text-primary);
  box-sizing: border-box;
  transition: var(--transition-fast);
  caret-color: var(--primary);
}

.form-input::placeholder {
  color: var(--text-disabled);
}

.form-input:focus {
  border-color: var(--primary);
  background: var(--surface);
  box-shadow: 0 0 0 4rpx rgba(26, 115, 232, 0.08);
}

/* ==================== 验证码区域 ==================== */
.captcha-item {
  margin-bottom: 28rpx;
}

.captcha-wrapper {
  display: flex;
  gap: var(--spacing-md);
}

.captcha-input-wrapper {
  flex: 1;
  min-width: 0;
}

.captcha-input {
  width: 100%;
}

.captcha-display {
  width: 260rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border: 2rpx solid var(--primary-lighter);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: var(--transition-fast);
}

.captcha-display:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #BBDEFB 0%, #E3F2FD 100%);
}

.captcha-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-dark);
  letter-spacing: 2rpx;
  font-family: 'Courier New', monospace;
}

.captcha-refresh-hint {
  font-size: 16rpx;
  color: var(--primary);
  margin-top: 4rpx;
  opacity: 0.7;
}

.captcha-refresh {
  font-size: 18rpx;
  color: var(--primary);
  margin-top: 2rpx;
}

.captcha-hint {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: var(--spacing-xs);
  text-align: right;
}

/* ==================== 登录按钮 ==================== */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(145deg, #1A73E8 0%, #4A90D9 100%);
  color: #ffffff;
  border-radius: var(--radius-xl);
  font-size: var(--font-xl);
  font-weight: 700;
  margin-top: 32rpx;
  border: none;
  letter-spacing: 6rpx;
  box-shadow: 0 6rpx 24rpx rgba(26, 115, 232, 0.35);
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(26, 115, 232, 0.25);
}

.login-btn[disabled] {
  opacity: 0.6;
  transform: none;
  box-shadow: none;
}

/* ==================== 底部链接 ==================== */
.form-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 28rpx;
  gap: var(--spacing-md);
}

.form-footer .link {
  font-size: var(--font-md);
  color: var(--primary);
  font-weight: 500;
  padding: 10rpx 4rpx;
}

.form-footer .link:active {
  opacity: 0.65;
}

.footer-dot {
  font-size: var(--font-xs);
  color: var(--border);
}

/* ==================== 安全提示 ==================== */
.security-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}

.tip-icon {
  font-size: var(--font-sm);
  margin-right: var(--spacing-sm);
}

.tip-text {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.5);
}

/* ==================== 动画 ==================== */
@keyframes ringPulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.08); opacity: 0.6; }
  100% { transform: scale(1); opacity: 1; }
}
