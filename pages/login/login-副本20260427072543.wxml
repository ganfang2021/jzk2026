<view class="login-container">
  <!-- 装饰性背景元素 -->
  <view class="deco-circle deco-1"></view>
  <view class="deco-circle deco-2"></view>
  <view class="deco-circle deco-3"></view>
  <view class="deco-circle deco-4"></view>

  <!-- 头部品牌区 -->
  <view class="login-header">
    <view class="logo-wrapper">
      <view class="logo-ring"></view>
      <view class="logo">
        <text class="logo-icon">🏥</text>
      </view>
    </view>
    <view class="title">急诊科预检分诊系统</view>
    <view class="subtitle">Emergency Triage Information System</view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <view class="login-card-header">
      <text class="card-header-icon">🔐</text>
      <text class="card-header-title">账号登录</text>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text>用户名</text>
      </view>
      <view class="input-wrapper">
        <text class="input-icon">👤</text>
        <input
          class="form-input"
          placeholder="请输入用户名"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text>密码</text>
      </view>
      <view class="input-wrapper">
        <text class="input-icon">🔒</text>
        <input
          class="form-input"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
          password
          maxlength="20"
        />
      </view>
    </view>

    <button
      class="login-btn"
      bindtap="onLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登  录'}}
    </button>

    <view class="form-footer">
      <text class="link" bindtap="onRegister">注册账号</text>
    </view>
  </view>
</view>
