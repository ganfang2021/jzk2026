<view class="login-container">
  <!-- 装饰性背景元素 -->
  <view class="deco-circle deco-1"></view>
  <view class="deco-circle deco-2"></view>
  <view class="deco-circle deco-3"></view>
  <view class="deco-circle deco-4"></view>

  <!-- 头部品牌区 -->
  <view class="login-header">
    <view class="logo-wrapper">
      <view class="logo-ring"></view>
      <view class="logo">
        <text class="logo-icon">🏥</text>
      </view>
    </view>
    <view class="title">急诊科预检分诊系统</view>
    <view class="subtitle">Emergency Triage Information System</view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <view class="login-card-header">
      <text class="card-header-title">账号登录</text>
    </view>

    <!-- 用户名 -->
    <view class="form-item">
      <view class="form-label">用户名</view>
      <input
        class="form-input"
        placeholder="请输入用户名"
        value="{{username}}"
        bindinput="onUsernameInput"
        maxlength="20"
      />
    </view>

    <!-- 密码 -->
    <view class="form-item">
      <view class="form-label">密码</view>
      <input
        class="form-input"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
        password
        maxlength="20"
      />
    </view>

    <!-- 验证码区域 -->
    <view class="form-item captcha-item">
      <view class="form-label">验证码</view>
      <view class="captcha-wrapper">
        <view class="captcha-input-wrapper">
          <input
            class="form-input captcha-input"
            placeholder="输入答案"
            value="{{captcha}}"
            bindinput="onCaptchaInput"
            type="number"
            maxlength="3"
          />
        </view>
        <view class="captcha-display" bindtap="onRefreshCaptcha">
          <text class="captcha-text">{{captchaText}}</text>
          <text class="captcha-refresh-hint">点击刷新</text>
        </view>
      </view>
    </view>

    <button
      class="login-btn"
      bindtap="onLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登 录'}}
    </button>

    <view class="form-footer">
      <text class="link" bindtap="onRegister">注册账号</text>
    </view>
  </view>

  <!-- 安全提示 -->
  <view class="security-tip">
    <text class="tip-text">🛡️ 您的数据已加密保护</text>
  </view>
</view>
