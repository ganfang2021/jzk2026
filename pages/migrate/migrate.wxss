.container {
  min-height: 100vh;
  background: var(--background);
  padding: var(--spacing-2xl);
}

.header-card {
  background: var(--primary-gradient-deep);
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
  color: #ffffff;
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-md);
}

.header-title {
  font-size: var(--font-xl);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}

.header-desc {
  font-size: var(--font-md);
  opacity: 0.9;
}

.card {
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  margin-bottom: var(--spacing-lg);
  color: var(--text-primary);
}

.status-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.status-item:last-child {
  border-bottom: none;
}

.status-label {
  font-size: var(--font-md);
  color: var(--text-secondary);
}

.status-value {
  font-size: var(--font-md);
  font-weight: 600;
}

.status-value.success {
  color: var(--success);
}

.status-value.error {
  color: var(--danger);
}

.status-value.warning {
  color: var(--warning);
}

.info-text {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.info-text text {
  font-size: var(--font-md);
  color: var(--text-secondary);
  line-height: 1.6;
}

.btn-area {
  margin-bottom: var(--spacing-lg);
}

.btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-xl);
  font-size: var(--font-lg);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary {
  background: var(--primary-gradient);
  color: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(26, 115, 232, 0.25);
}

.btn-outline {
  background: var(--surface);
  border: 2rpx solid var(--primary);
  color: var(--primary);
}

.success-tip {
  text-align: center;
  padding: var(--spacing-xl);
  background: #E8F5E9;
  border-radius: var(--radius-lg);
  color: var(--success);
  font-size: var(--font-md);
}

.error-tip {
  text-align: center;
  padding: var(--spacing-xl);
  background: #FFEBEE;
  border-radius: var(--radius-lg);
  color: var(--danger);
  font-size: var(--font-md);
  margin-bottom: var(--spacing-md);
}

.progress-area {
  padding: var(--spacing-md) 0;
}

.progress-text {
  display: block;
  text-align: center;
  margin-top: var(--spacing-md);
  font-size: var(--font-md);
  color: var(--text-secondary);
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.result-info text {
  font-size: var(--font-md);
  color: var(--text-primary);
}
